bannerStickyHeight: 100,
bannerCommonHeight: 520,
bannerWidth: 767,
bannerLink: 'https://www.empik.com/swiatowy-dzien-ksiazki?utm_source=lubimy_czytac&utm_medium=sponsoring',
bannerSrc: 'https://s.lubimyczytac.pl/upload/topbanner/189/1359415.jpg',
};
}
return {
bannerTopHeight: 120,
bannerCenterHeight: 300,
bannerStickyHeight: 100,
bannerCommonHeight: 520,
bannerWidth: 1920,
bannerLink: 'https://www.empik.com/swiatowy-dzien-ksiazki?utm_source=lubimy_czytac&utm_medium=sponsoring',
bannerSrc: 'https://s.lubimyczytac.pl/upload/topbanner/189/1359414.jpg',
};
}
function applyBaseBannerStyles(){const {
bannerTopHeight: nextBannerTopHeight,
bannerCenterHeight: nextBannerCenterHeight,
bannerStickyHeight: nextBannerStickyHeight,
bannerCommonHeight: nextBannerCommonHeight,
bannerWidth: nextBannerWidth,
bannerLink: nextBannerLink,
bannerSrc,
}
= getConfig();
bannerTopHeight = nextBannerTopHeight;
bannerCenterHeight = nextBannerCenterHeight;
bannerStickyHeight = nextBannerStickyHeight;
bannerCommonHeight = nextBannerCommonHeight;
bannerWidth = nextBannerWidth;
bannerLink = nextBannerLink;
const stickyBackgroundOffset = bannerTopHeight + bannerCenterHeight;
setStyles(adsContainer,{width: `${bannerWidth}px`,
height: `${bannerTopHeight}px`,
backgroundImage: `url("${bannerSrc}")`,
backgroundSize: `${bannerWidth}px ${bannerCommonHeight}px`,
backgroundPosition: '50% 0',
});
setStyles(adsContainerSticky,{width: `${bannerWidth}px`,
height: `${bannerStickyHeight}px`,
transform: `translateY(${bannerTopHeight}px)`,
backgroundImage: `url("${bannerSrc}")`,
backgroundPosition: `center -${stickyBackgroundOffset}px`,
backgroundSize: `${bannerWidth}px ${bannerCommonHeight}px`,
});
adsLinkContainer.setAttribute('href', bannerLink);
}
function applyExpandedState(){const bannerNoStickyHeight = bannerTopHeight + bannerCenterHeight;
setStyles(adsContainer,{width: `${bannerWidth}px`,
height: `${bannerCenterHeight}px`,
transition: 'background-position 370ms cubic-bezier(0.55, 0.06, 0.68, 0.19),height 450ms linear',
backgroundPosition: `center -${bannerTopHeight}px`,
});
setStyles(adsContainerSticky,{opacity: '0',
transform: `translateY(${bannerNoStickyHeight}px)`,
});
if (isMobile){body.classList.add('is-sponsorship-open');
}
body.style.paddingTop = `${bannerCenterHeight}px`;
if (expandButton){expandButton.style.top = `-${bannerTopHeight}px`;
}
if (collapseButton){collapseButton.style.top = '0';
}
isCollapsed = 1;
}
function applyCollapsedState(){setStyles(adsContainer,{width: `${bannerWidth}px`,
height: `${bannerTopHeight}px`,
transition: 'background-position 370ms cubic-bezier(0.55, 0.06, 0.68, 0.19),height 450ms linear',
backgroundPosition: '50% 0',
});
setStyles(adsContainerSticky,{opacity: '1',
transform: `translateY(${bannerTopHeight}px)`,
});
if (isMobile){body.classList.remove('is-sponsorship-open');
}
body.style.paddingTop = `${bannerTopHeight}px`;
if (expandButton){expandButton.style.top = '0';
}
if (collapseButton){collapseButton.style.top = `-${bannerTopHeight}px`;
}
isCollapsed = 0;
}
function applyScrollState(){if (isCollapsed !== 0){applyCollapsedState();
}
if (lastScrollY > 0){body.classList.add('is-top-sponsorship-fixed');
adsContainerHld.classList.add('is-sticky-small');
setStyles(adsContainer,{height: `${bannerStickyHeight}px`,
backgroundPosition: `center -${bannerStickyHeight}px`,
transition: 'height 450ms linear, background-position 450ms cubic-bezier(0.55, 0.06, 0.68, 0.19),transform 450ms linear',
});
if (lastScrollY < bannerTopHeight - bannerStickyHeight){body.style.paddingTop = `${bannerTopHeight - bannerStickyHeight}px`;
}
}
else {
body.classList.remove('is-top-sponsorship-fixed');
adsContainerHld.classList.remove('is-sticky-small');
setStyles(adsContainer,{height: `${bannerTopHeight}px`,
backgroundPosition: 'center 0',
transition: 'height 450ms linear, background-position 450ms cubic-bezier(0.55, 0.06, 0.68, 0.19),transform 450ms linear',
});
body.style.paddingTop = `${bannerTopHeight}px`;
}
animationFrameId = null;
}
function onScroll(){lastScrollY = window.pageYOffset;
if (animationFrameId !== null){return;
}
animationFrameId = window.requestAnimationFrame(applyScrollState);
}
function onResize(){const nextIsMobile = window.innerWidth < 1200;
if (nextIsMobile === isMobile){return;
}
isMobile = nextIsMobile;
applyBaseBannerStyles();
if (window.pageYOffset > 0){onScroll();
return;
}
if (isCollapsed !== 0){applyExpandedState();
return;
}
applyCollapsedState();
}
applyBaseBannerStyles();
defer(() => {
setTimeout(() => {
adsContainerSticky.style.opacity = '1';
}, 1000);
});
defer(() => {
if (typeof gtag !== 'undefined'){gtag('event', 'sponsoring',{sponsoring_event_name: 'sponsoring',
sponsoring_event_type: 'view',
sponsoring_event_label: 'Empik _ kwiecień 2',
});
}
});
window.addEventListener('scroll', onScroll,{passive: true });
window.addEventListener('resize', onResize);
if (expandButton){expandButton.addEventListener('click', () => {
applyExpandedState();
});
}
if (collapseButton){collapseButton.addEventListener('click', () => {
applyCollapsedState();
});
}
if (adsLinkContainer){adsLinkContainer.addEventListener('click', () => {
if (typeof gtag !== 'undefined'){gtag('event', 'sponsoring',{sponsoring_event_name: 'sponsoring',
sponsoring_event_type: 'click',
sponsoring_event_label: 'Empik _ kwiecień 2',
});
}
});
}
});</script><div id="top-sponsorship-banner" class="top-sponsorship-banner d-block" style="background: #fbbc13"><div
