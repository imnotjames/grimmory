let initCode = () => {
let sliderContainer = $('.jsSliderHtmlLazy-slider-author-books');
let sliderArrow = sliderContainer.find('.jsSliderHtmlBtn');
let getSliderItems = () => {
$.ajax({
type: "GET",
url: "/content/fetchAuthorBooks/31/6/5223841",
async: true,
cache: true,
success: function (response){if (response.code == 'OK'){document.querySelector('#slider-author-books .jsSliderHtmlScroll').innerHTML += (response.data.content);
sliderContainer.find('[data-toggle="tooltip"]').tooltip();
let strona = 'Książka';
/* mwi limit eventow */
document.querySelectorAll('#ksiazki-rekomendacje #slider-99 a.book-url').forEach((el) => {
el.addEventListener('click', function (){gtag("event", "Rekomendacje",{misc_event_name: strona+" - rekomendacje dla ciebie",
misc_event_type: "click"
});
});
});
}
},
beforeSend: function(){sliderContainer.find('[data-toggle="tooltip"]').tooltip('disable');
}
});
}
sliderContainer.on('mousedown.sliderLoad touchstart.sliderLoad mouseenter.sliderLoad', e => {
getSliderItems();
sliderContainer.off('mousedown.sliderLoad touchstart.sliderLoad mouseenter.sliderLoad')
});
}
if( document.readyState !== 'loading' ){initCode();
}
else {
document.addEventListener('DOMContentLoaded', function (){initCode();
});
}
